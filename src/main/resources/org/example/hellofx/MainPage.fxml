<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.input.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="scenePane" prefHeight="578.0" prefWidth="885.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UserInterface.MainController">
   <children>
      <MenuBar layoutX="-1.0" layoutY="2.0" prefHeight="25.0" prefWidth="890.0">
        <menus>
          <Menu mnemonicParsing="false" text="File">
            <items>
                  <MenuItem mnemonicParsing="false" onAction="#handleOpenFile" text="Open">
                     <accelerator>
                        <KeyCodeCombination alt="UP" code="O" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                     </accelerator>
                  </MenuItem>
                  <MenuItem mnemonicParsing="false" onAction="#handleSaveFile" text="Save As">
                     <accelerator>
                        <KeyCodeCombination alt="UP" code="S" control="DOWN" meta="UP" shift="UP" shortcut="UP" />
                     </accelerator>
                  </MenuItem>
                  <CheckMenuItem mnemonicParsing="false" selected="true" text="Auto Save" />
                  <SeparatorMenuItem mnemonicParsing="false" />
              <MenuItem mnemonicParsing="false" onAction="#handleCloseApp" text="Close" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Edit">
            <items>
              <MenuItem mnemonicParsing="false" text="Delete" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Help">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>

             <Label fx:id="outputLabel" layoutX="32.0" layoutY="89.0" text="Please import file to process">
           <font>
               <Font size="14.0" />
           </font>
       </Label>
      <Label fx:id="myLabel" alignment="CENTER" layoutX="306.0" layoutY="74.0" prefHeight="70.0" prefWidth="278.0" text="Select Dealer">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <Label layoutX="393.0" layoutY="253.0" text="Inventory">
         <font>
            <Font size="25.0" />
         </font>
      </Label>

      <!--        Table show vehicle inventory-->
      <TableView fx:id="vehicleTable" editable="true" layoutY="310.0" prefHeight="268.0" prefWidth="890.0" tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="idCol" prefWidth="151.0" text="ID" />
          <TableColumn fx:id="typeCol" prefWidth="165.0" text="Type" />
            <TableColumn fx:id="makeCol" prefWidth="162.0" text="Make" />
            <TableColumn fx:id="modelCol" prefWidth="174.0" text="Model" />
          <TableColumn fx:id="priceCol" minWidth="0.0" prefWidth="234.0" text="Price" />
            <TableColumn fx:id="statusCol" prefWidth="304.0" text="Status" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ToolBar layoutY="27.0" prefHeight="41.0" prefWidth="890.0">
        <items>
            <Button fx:id="addVehicleButton" mnemonicParsing="false" text="➕ Add Vehicle">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
            <Button fx:id="deleteVehicleButton" mnemonicParsing="false" text="➖ Delete Vehicle">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
          <Button mnemonicParsing="false" text="Transfer Vehicle">
               <font>
                  <Font size="15.0" />
               </font></Button>
            <Button mnemonicParsing="false" text="Rent Vehicle">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" text="Return Vehicle">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" text="Add Dealer">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>

                  <ChoiceBox fx:id="dealerChoiceBox" prefHeight="25.0" prefWidth="127.0" />
        </items>
         <padding>
            <Insets left="10.0" />
         </padding>
      </ToolBar>
      <ListView fx:id="listView" layoutX="654.0" layoutY="110.0" prefHeight="150.0" prefWidth="154.0" />

         </children>
</AnchorPane>
